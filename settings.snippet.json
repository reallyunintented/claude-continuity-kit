{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "$HOME/.claude/hooks/memory-guard.sh" }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "$HOME/.claude/hooks/session-reminder.sh" }
        ]
      },
      {
        "hooks": [
          { "type": "command", "command": "$HOME/.claude/hooks/handoff-surface.sh" }
        ]
      }
    ]
  }
}
